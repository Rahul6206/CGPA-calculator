---
const columns = [
  {
    title: 'Converters',
    links: [
      { label: 'SGPA to CGPA', href: '/sgpa-to-cgpa' },
      { label: 'CGPA to Percentage', href: '/cgpa-to-percentage' },
      { label: 'Percentage to CGPA', href: '/percentage-to-cgpa' },
      { label: 'Percentage to SGPA', href: '/percentage-to-sgpa' },
    ],
  },
  {
    title: 'Advanced',
    links: [
      { label: 'Subject-wise SGPA', href: '/sgpa-calculator' },
      { label: 'Target CGPA Planner', href: '/target-cgpa' },
      { label: 'Attendance Planner', href: '/attendance-planner' },
    ],
  },
  {
    title: 'Utility',
    links: [
      { label: 'Settings', href: '/settings' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Contact Us', href: '/contact' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms & Conditions', href: '/terms' },
    ],
  },
];
---

<footer class="border-t border-hairline bg-canvas" id="main-footer">
  <div class="mx-auto max-w-[1200px] px-4 py-16 md:px-6">
    <div class="flex flex-col md:flex-row gap-8 md:justify-between">
      <!-- Brand Column -->
      <div class="md:w-1/4">
        <div class="flex items-center gap-2 mb-4">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="28" height="28" rx="6" fill="#171717"/>
            <text x="14" y="19" text-anchor="middle" fill="white" font-size="14" font-weight="600" font-family="Inter, sans-serif">S</text>
          </svg>
          <span class="body-sm-strong text-ink">Student Utility Hub</span>
        </div>
        <p class="body-sm text-mute max-w-[240px]">
          Free, fast, and accurate academic calculators. No sign-up required.
        </p>
      </div>

      <!-- Link Columns -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:w-3/4">
        {columns.map((col) => (
          <div>
            <h3 class="caption-mono text-mute mb-4 uppercase">{col.title}</h3>
            <ul class="flex flex-col gap-2.5 list-none p-0 m-0">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="body-sm text-body no-underline transition-colors duration-150 hover:text-ink"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-hairline pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="caption text-mute">© 2024 Student Utility Hub. Built for students, by students.</p>
      <p class="caption text-mute">
        Powered by <a href="https://astro.build" class="text-body hover:text-ink transition-colors" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
    </div>
  </div>
</footer>
