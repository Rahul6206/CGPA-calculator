---
import BaseLayout from '../layouts/BaseLayout.astro';
import SgpaToCgpa from '../components/calculators/SgpaToCgpa.tsx';
---

<BaseLayout
  title="SGPA to CGPA Calculator — Convert Semester GPA Instantly"
  description="Calculate your cumulative CGPA from multiple semesters' SGPA. Free, instant, accurate. Add as many semesters as needed."
  canonical="/sgpa-to-cgpa"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studentutilityhub.com" },
      { "@type": "ListItem", "position": 2, "name": "SGPA to CGPA", "item": "https://studentutilityhub.com/sgpa-to-cgpa" }
    ]
  })} />

  <main class="mx-auto max-w-[700px] px-4 py-10 sm:py-16 md:px-6">
    <!-- Breadcrumb -->
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5 body-sm text-mute">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink font-medium">SGPA to CGPA</li>
      </ol>
    </nav>

    <h1 class="display-lg text-ink mb-2">SGPA to CGPA Calculator.</h1>
    <p class="body-lg text-body mb-8">
      Enter your semester SGPAs below to calculate your cumulative CGPA instantly.
    </p>

    <SgpaToCgpa client:load />

    <!-- FAQ -->
    <section class="mt-12">
      <h2 class="display-sm text-ink mb-4">Frequently asked questions.</h2>
      <div class="flex flex-col gap-4">
        <div class="rounded-[8px] bg-canvas p-5 shadow-level-1">
          <h3 class="body-sm-strong text-ink mb-1">How is CGPA calculated from SGPA?</h3>
          <p class="body-sm text-body">CGPA is the simple average of all your semester SGPAs. Add up all SGPAs and divide by the number of semesters.</p>
        </div>
        <div class="rounded-[8px] bg-canvas p-5 shadow-level-1">
          <h3 class="body-sm-strong text-ink mb-1">Is this formula accurate for my university?</h3>
          <p class="body-sm text-body">This uses the standard averaging method. Some universities use credit-weighted CGPA — for that, use our Subject-wise SGPA calculator.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
