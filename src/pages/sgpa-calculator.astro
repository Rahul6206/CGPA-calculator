---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubjectSgpaCalculator from '../components/calculators/SubjectSgpaCalculator.tsx';
---

<BaseLayout
  title="Subject-wise SGPA Calculator — Add Subjects & Credits"
  description="Calculate your SGPA by adding individual subjects with credits and grades. Dynamic form with instant results and breakdown."
  canonical="/sgpa-calculator"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://studentutilityhub.com" },
      { "@type": "ListItem", "position": 2, "name": "Subject-wise SGPA", "item": "https://studentutilityhub.com/sgpa-calculator" }
    ]
  })} />

  <main class="mx-auto max-w-[800px] px-4 py-10 sm:py-16 md:px-6">
    <nav class="mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5 body-sm text-mute">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink font-medium">Subject-wise SGPA</li>
      </ol>
    </nav>

    <h1 class="display-lg text-ink mb-2">Subject-wise SGPA Calculator.</h1>
    <p class="body-lg text-body mb-8">Add each subject with its credits and grade to calculate your exact semester SGPA.</p>

    <SubjectSgpaCalculator client:load />
  </main>
</BaseLayout>
